# Example environment variables for this monorepo.
# Copy needed values into:
# - server/.env
# - client/.env.development (or client/.env)

# =====================
# Server (server/.env)
# =====================
NODE_ENV=development
PORT=3000

# Prisma / PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ricci_internal_bot?schema=public

# Auth
JWT_SECRET=change-me-to-a-strong-secret
JWT_EXPIRES_IN=7d

# Telegram bot
BOT_TOKEN=
BOT_WEBHOOK_SECRET=

# External integrations
INTEGRATION_API_KEY=

# =====================
# Client (client/.env.development)
# =====================
VITE_API_URL=http://localhost:3000/api
